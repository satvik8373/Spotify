rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    // Users collection - read own profile, admins can read all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Admin collection - only admins can access
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // Songs - public read, admin write
    match /songs/{songId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Albums - public read, admin write
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Playlists - public read, owner/admin write
    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy.uid == request.auth.uid || isAdmin()
      );
    }
    
    // Artists - public read, admin write
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User's liked songs subcollection
    match /users/{userId}/likedSongs/{songId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // All other collections - admin only
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
