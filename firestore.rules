rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function ownerFromCreatedBy(data) {
      return signedIn() &&
        data.keys().hasAny(['createdBy']) &&
        data.createdBy is map &&
        (
          (data.createdBy.keys().hasAny(['uid']) && data.createdBy.uid == request.auth.uid) ||
          (data.createdBy.keys().hasAny(['id']) && data.createdBy.id == request.auth.uid) ||
          (data.createdBy.keys().hasAny(['_id']) && data.createdBy._id == request.auth.uid)
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin();

      match /likedSongs/{songId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /pushTokens/{tokenId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /spotifyTokens/{tokenId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /spotifySync/{docId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /spotifyLikedSongs/{songId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Legacy mobile format. New clients must use users/{uid}/likedSongs/{songId}.
    match /likedSongs/{userId} {
      allow read, delete: if isOwner(userId) || isAdmin();
      allow create, update: if false;
    }

    match /playlists/{playlistId} {
      allow get, list: if resource.data.isPublic == true ||
        (signedIn() && ownerFromCreatedBy(resource.data)) ||
        isAdmin();
      allow create: if signedIn() &&
        ownerFromCreatedBy(request.resource.data);
      allow update: if isAdmin() ||
        (signedIn() && ownerFromCreatedBy(resource.data) && ownerFromCreatedBy(request.resource.data));
      allow delete: if isAdmin() ||
        (signedIn() && ownerFromCreatedBy(resource.data));
    }

    match /playlist_shares/{shareId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /songs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /albums/{albumId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /trendingSongs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /mood_playlist_cache/{docId} {
      allow read, write: if isAdmin();
    }

    match /mood_playlist_rate_limits/{docId} {
      allow read, write: if isAdmin();
    }

    match /mood_playlist_analytics/{docId} {
      allow read, write: if isAdmin();
    }

    match /mood_playlist_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    match /mood_playlist_alerts/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
